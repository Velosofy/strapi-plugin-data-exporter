{
  "name": "@velosofy/strapi-plugin-data-exporter",
  "version": "1.0.0",
  "description": "A Strapi v5 plugin to export any content type data to CSV, JSON, or XLSX, with column selection support.",
  "keywords": [
    "strapi",
    "strapi-plugin",
    "export",
    "csv",
    "json",
    "xlsx",
    "excel",
    "data-export",
    "content-type",
    "strapi5"
  ],
  "license": "MIT",
  "author": "Velosofy <contact@velosofy.dev>",
  "homepage": "https://github.com/Velosofy/strapi-data-exporter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Velosofy/strapi-data-exporter.git"
  },
  "bugs": {
    "url": "https://github.com/Velosofy/strapi-data-exporter/issues"
  },
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test:ts:front": "run -T tsc -p admin/tsconfig.json",
    "test:ts:back": "run -T tsc -p server/tsconfig.json"
  },
  "dependencies": {
    "papaparse": "^5.5.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@strapi/design-system": "^2.0.0-rc.30",
    "@strapi/icons": "^2.0.0-rc.30",
    "@strapi/sdk-plugin": "^6.0.1",
    "@strapi/strapi": "^5.42.0",
    "@strapi/typescript-utils": "^5.42.0",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.8.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.8.9",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.4.0",
    "typescript": "^5.0.2"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.0.0-rc.30",
    "@strapi/icons": "^2.0.0-rc.30",
    "@strapi/strapi": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-intl": "^6.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0 <=22.x.x",
    "npm": ">=6.0.0"
  },
  "strapi": {
    "kind": "plugin",
    "name": "data-exporter",
    "displayName": "Data Exporter",
    "description": "Export any Strapi content type to CSV with full column selection control.",
    "required": false
  }
}
